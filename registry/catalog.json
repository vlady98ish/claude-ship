  "stack_presets": {
    "react-native": {
      "detect": {
        "files": ["app.json", "app.config.js", "app.config.ts"],
        "package_deps": ["react-native", "expo"],
        "any_match": true
      },
      "recommended_skills": [
        "vercel-react-native",
        "ui-ux-pro-max",
        "expo-native-ui",
        "expo-deployment"
      ],
      "optional_skills": [
        "callstack-react-native",
        "expo-data-fetching",
        "expo-tailwind"
      ],
      "default_config": {
        "test_command": "npm test",
        "work_type_detection": {
          "ui": {
            "paths": ["screens/", "components/", "app/"],
            "extensions": [".tsx", ".jsx"]
          },
          "backend": {
            "paths": ["services/", "api/", "db/", "server/"],
            "extensions": [".ts", ".js", ".sql"]
          },
          "domain": { "paths": ["domain/", "lib/", "utils/", "hooks/"] }
        }
      }
    },
    "nextjs": {
      "detect": {
        "files": ["next.config.js", "next.config.mjs", "next.config.ts"],
        "package_deps": ["next"],
        "any_match": true
      },
      "recommended_skills": [
        "vercel-react",
        "web-design-guidelines",
        "nextjs-app-router",
        "webapp-testing"
      ],
      "optional_skills": ["tailwind-design-system", "frontend-design"],
      "default_config": {
        "test_command": "npm test",
        "work_type_detection": {
          "ui": {
            "paths": ["app/", "pages/", "components/", "src/components/"],
            "extensions": [".tsx", ".jsx"]
          },
          "backend": {
            "paths": ["api/", "app/api/", "lib/", "server/"],
            "extensions": [".ts", ".js"]
          },
          "domain": { "paths": ["lib/", "utils/", "helpers/"] }
        }
      }
    },
    "vue": {
      "detect": {
        "files": [
          "nuxt.config.ts",
          "nuxt.config.js",
          "vue.config.js",
          "vite.config.ts"
        ],
        "package_deps": ["vue", "nuxt"],
        "any_match": true
      },
      "recommended_skills": ["web-design-guidelines", "webapp-testing"],
      "optional_skills": ["tailwind-design-system", "frontend-design"],
      "default_config": {
        "test_command": "npm test",
        "work_type_detection": {
          "ui": {
            "paths": ["components/", "pages/", "layouts/", "src/components/"],
            "extensions": [".vue", ".tsx"]
          },
          "backend": {
            "paths": ["server/", "api/", "composables/"],
            "extensions": [".ts", ".js"]
          },
          "domain": { "paths": ["utils/", "lib/", "helpers/"] }
        }
      }
    },
    "python": {
      "detect": {
        "files": ["requirements.txt", "pyproject.toml", "setup.py", "Pipfile"],
        "package_deps": ["fastapi", "flask", "django"],
        "any_match": true
      },
      "recommended_skills": ["python-testing"],
      "optional_skills": [],
      "default_config": {
        "test_command": "pytest",
        "work_type_detection": {
          "backend": {
            "paths": ["app/", "src/", "api/", "routes/"],
            "extensions": [".py"]
          },
          "domain": {
            "paths": ["models/", "schemas/", "utils/", "lib/", "core/"]
          }
        }
      }
    },
    "go": {
      "detect": {
        "files": ["go.mod"],
        "any_match": true
      },
      "recommended_skills": [],
      "optional_skills": [],
      "default_config": {
        "test_command": "go test ./...",
        "work_type_detection": {
          "backend": {
            "paths": ["cmd/", "internal/", "pkg/", "api/"],
            "extensions": [".go"]
          },
          "domain": { "paths": ["internal/domain/", "pkg/", "lib/"] }
        }
      }
    },
    "supabase": {
      "detect": {
        "files": ["supabase/config.toml"],
        "package_deps": ["@supabase/supabase-js"],
        "any_match": true
      },
      "recommended_skills": ["supabase-postgres"],
      "optional_skills": ["nextjs-supabase-auth"],
      "default_config": {}
    }
  }
}
